#!/usr/bin/env bash
#
# Session Wayland de l'enfant. C'est SDDM qui lance ce script (via l'entrée
# /usr/share/wayland-sessions/sesame.desktop).
#
# ## Pourquoi Wayland, et pourquoi `cage`
#
# En session X11, SDDM démarrait le serveur X AVANT d'exécuter ce script : le
# kiosque héritait d'un écran tout prêt, sans gestionnaire de fenêtres. Cette
# époque est finie — Plasma 6 a sorti la session X11 dans un paquet séparé
# (`plasma-x11-session`), et ces machines ne l'ont pas.
#
# En session Wayland, SDDM ne démarre RIEN : le compositeur EST le serveur.
# C'est donc à nous d'apporter le nôtre pour la porte. Ce sera `cage`, un
# compositeur kiosque qui n'implémente qu'une seule politique : une
# application, plein écran, et rien d'autre. Alt+Tab, Alt+F4, barre des tâches :
# cage ne les implémente pas. Ils ne sont pas désactivés, ils N'EXISTENT PAS.
# Même garantie qu'un X nu, mais par conception plutôt que par absence — et en
# prime, `--kiosk` fonctionne enfin pour de vrai.
#
# ## Les quatre étapes. Lis-les dans l'ordre :
#
#   1. le serveur démarre ;
#   2. cage prend l'écran et y affiche le contrôle ;
#   3. on ne passe la main que si l'API dit que l'ordinateur est gagné ;
#   4. ALORS SEULEMENT le bureau est lancé.
#
# Le bureau n'est pas « bloqué » : il n'existe simplement pas encore. C'est
# toute l'idée.

set -u

BIN_DIR="${SESAME_BIN_DIR:-/usr/local/bin}"

log() {
    echo "sesame-session: $*" >&2
    command -v logger >/dev/null 2>&1 && logger -t sesame "$*"
}

refuser() {
    log "$* — pas de bureau"
    kill "$SERVER_PID" 2>/dev/null
    exit 1
}

# --- 1. Le serveur : unique propriétaire de la base, vivant toute la session.
"$BIN_DIR/sesame" &
SERVER_PID=$!
log "serveur démarré (pid $SERVER_PID)"

# --- 2. La porte, dans son compositeur.
#
# Si `cage` manque, ou s'il n'obtient pas l'écran (siège déjà pris, DRM occupé),
# il sort en erreur et le contrôle n'a jamais été affiché. L'étape 3 le verra.
cage -- "$BIN_DIR/sesame-kiosk"
log "le kiosque a rendu la main (cage a rendu $?)"

# --- 3. La vérité, c'est l'API — PAS le code de sortie de cage.
#
# Le contrat « code 0 → bureau » passe désormais À TRAVERS cage, et rien ne
# garantit que cage propage le code de son enfant. S'il rendait 0 quoi qu'il
# arrive, la serrure s'ouvrirait toute seule.
#
# Une serrure qui échoue OUVERTE n'est pas une serrure. On repose donc la
# question à la seule source de vérité — `policy::evaluate`, derrière
# /api/gate. `--check` : une requête, pas de navigateur, sort 0 ou 1.
#
# Conséquence voulue : cage absent, cage cassé, kiosque planté, serveur muet →
# tout finit ici, sur un exit 1. Fermé par construction, pas par confiance.
"$BIN_DIR/sesame-kiosk" --check || refuser "l'ordinateur n'est pas débloqué"
log "contrôle réussi — on ouvre le bureau"

# --- L'horloge. Elle décompte, prévient, et ferme la session à la fin.
"$BIN_DIR/sesame-timer" &
TIMER_PID=$!
log "minuteur démarré (pid $TIMER_PID)"

# --- 4. Le bureau.
#
# PAS de `exec`, et ce n'est pas un détail de style. SDDM lit le code de sortie
# de CE script comme le verdict de la session : tout ce qui n'est pas 0, il
# l'appelle « Process crashed », il COUPE l'autologin, et il s'arrête là.
#
# Avec `exec`, le code de sortie de la session était celui de Plasma. Et quand
# le minuteur fermait la session en TUANT Plasma, Plasma mourait avec une
# erreur : SDDM croyait à un plantage, coupait l'autologin, et l'enfant restait
# dehors — écran noir, jusqu'à ce qu'un adulte redémarre la machine.
#
# Cette protection de SDDM est BONNE : un vrai plantage ne doit pas boucler à
# l'infini devant un enfant. Le tort était de lui mentir. Une session qui se
# termine parce que le temps est écoulé n'est PAS un plantage — alors on lui
# rend 0, et SDDM ramène l'enfant à la porte, comme prévu.
#
# Le piège inverse est gardé plus haut : contrôle non passé, cage cassé, kiosque
# planté → on est déjà sorti en 1, et là oui, SDDM doit s'arrêter et laisser
# entrer un adulte.
#
# Le `trap` couvre le dernier recours du minuteur (`loginctl terminate-session`,
# qui nous envoie un SIGTERM à nous aussi) : là encore, la session se termine,
# elle ne plante pas.
trap 'exit 0' TERM

startplasma-wayland
log "le bureau s'est terminé (code $?) — fin de session"

kill "$SERVER_PID" "$TIMER_PID" 2>/dev/null
exit 0
